# --- App ---
NODE_ENV=development
PORT=3000

# --- Database (MongoDB / Mongoose) ---
# MongoDB standalone là đủ (code không dùng transaction nên KHÔNG cần replica set).
#  - Local:  mongodb://localhost:27017/auto_social
#  - Atlas:  mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/auto_social?retryWrites=true&w=majority
DATABASE_URL="mongodb://localhost:27017/auto_social"

# --- Auth / JWT ---
JWT_ACCESS_SECRET=change_me_to_a_long_random_string
JWT_REFRESH_SECRET=change_me_to_another_long_random_string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- CORS ---
CORS_ORIGIN=http://localhost:5174

# URL công khai của chính API này — dùng để dựng link ảnh/video đã upload
# (vd "<API_PUBLIC_URL>/uploads/facebook-posts/xxx.jpg"). Khớp PORT ở trên.
API_PUBLIC_URL=http://localhost:3000

# --- Default admin seed (tùy chọn override; mặc định: adminleducanh / Leducanh25@) ---
ADMIN_USERNAME=adminleducanh
ADMIN_PASSWORD=Leducanh25@

# --- Facebook (kết nối tài khoản qua OAuth + Graph API) ---
# Lấy từ Meta App Dashboard (developers.facebook.com) > Settings > Basic.
# Để TRỐNG nếu chưa dùng — endpoint Facebook sẽ báo "chưa cấu hình" thay vì lỗi.
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_GRAPH_VERSION=v23.0

# --- Instagram (Instagram API with Instagram Login) ---
# Lấy từ Meta App Dashboard > Instagram > API setup with Instagram login.
# Để TRỐNG nếu chưa dùng — endpoint Instagram sẽ báo "chưa cấu hình" thay vì lỗi.
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=

# --- OpenAI (gợi ý nội dung comment bằng AI) ---
# Lấy API key tại https://platform.openai.com/api-keys.
# Để TRỐNG nếu chưa dùng — endpoint gợi ý comment sẽ báo "chưa cấu hình".
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
